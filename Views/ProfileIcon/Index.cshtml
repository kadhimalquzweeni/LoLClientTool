@model LoLClientTool.Models.ProfileIconViewModel

@{
    ViewData["Title"] = "LoL Profile Icon Changer";
}

<div class="page-shell">
    <section class="hero">
        <div class="hero-content">
            <h1>Profile Icon Changer</h1>

            <p>
                Choose a profile icon and apply it directly to your local League Client.
                You can also enter an icon ID manually.
            </p>
        </div>
    </section>

    <div class="status-panel status-panel-row">
        <div>
            <strong>Status:</strong> @Model.StatusMessage
        </div>

        <a asp-action="Index" class="btn btn-secondary">
            Refresh Status
        </a>
    </div>

    <div class="form-panel">
        <h2 class="section-title">Manual Icon ID</h2>

        <p class="muted-text">
            Enter a profile icon ID below. Enter 202 for no icon.
        </p>

        <form asp-action="Index" method="post">
            <div class="mb-3">
                <label asp-for="IconId" class="form-label">Profile Icon ID</label>

                <input asp-for="IconId"
                       class="form-control"
                       disabled="@(!Model.IsLeagueClientRunning)" />

                <span asp-validation-for="IconId" class="text-danger"></span>
            </div>

            <button type="submit"
                    class="btn btn-primary"
                    disabled="@(!Model.IsLeagueClientRunning)">
                Set Profile Icon
            </button>
        </form>
    </div>

    <hr />

    <h2 class="section-title">Profile Icons 50–78</h2>

    <p class="muted-text">
        Click Set under an icon to apply it to your League profile.
    </p>

    <div class="icon-grid">
        @foreach (var icon in Model.AvailableIcons)
        {
            <div class="icon-card">
                <img src="@icon.ImageUrl"
                     alt="Profile icon @icon.IconId"
                     width="64"
                     height="64"
                     loading="lazy" />

                <p>ID: @icon.IconId</p>

                <form asp-action="Index" method="post">
                    <input type="hidden" name="IconId" value="@icon.IconId" />

                    <button type="submit"
                            class="btn btn-primary"
                            disabled="@(!Model.IsLeagueClientRunning)">
                        Set
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}