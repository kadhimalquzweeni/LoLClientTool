@{
    ViewData["Title"] = "Home";
}

<div class="page-shell">
    <section class="hero">
        <div class="hero-content">
            <h1>LoL Client Tool</h1>

            <p>
                A local ASP.NET Core MVC tool for customising your League Client profile.
                Change your profile icon, browse champion backgrounds, and set profile backgrounds from a clean web interface.
            </p>
        </div>
    </section>

    <div class="tool-grid">
        <a class="tool-card" asp-controller="ProfileIcon" asp-action="Index">
            <h2>Profile Icon Changer</h2>
            <p>
                Browse available profile icons and set one directly through your local League Client.
            </p>
        </a>

        <a class="tool-card" asp-controller="ProfileBackground" asp-action="Index">
            <h2>Profile Background Changer</h2>
            <p>
                Browse champions, view their skins, and set a splash art as your profile background.
            </p>
        </a>

        <a class="tool-card" asp-controller="ProfileStatus" asp-action="Index">
            <h2>Profile Status Changer</h2>
            <p>
                Update your League Client status message from the local web interface.
            </p>
        </a>
        <a class="tool-card" asp-controller="ChallengeTokens" asp-action="Index">
            <h2>Challenge Tokens</h2>
            <p>
                Clear selected League Challenge Tokens from your profile banner.
            </p>
        </a>
        <a class="tool-card" asp-controller="ProfileBanner" asp-action="Index">
            <h2>Profile Banner</h2>
            <p>
                Set your League profile banner accent, including the last-rank banner.
            </p>
        </a>
    </div>
</div>